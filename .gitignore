--- .gitignore (原始)
```
# Dependencies
node_modules/

# Build artifacts
dist/

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/

# Log files
*.log

# Temporary files
*.tmp
*.swp

# Compiled files
*.pyc
__pycache__/

# Package lock files
package-lock.json
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

```

+++ .gitignore (修改后)
```
# Dependencies
node_modules/

# Build outputs
dist/
build/
target/

# Environment variables
.env
.env.local
.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.pipenv
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled files
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# OS generated files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
